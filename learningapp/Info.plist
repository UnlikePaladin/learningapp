<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>UILaunchStoryboardName</key>
	<string>LaunchScreen</string>

	<!-- Custom Study Pack file type -->
	<!-- Exported because this app is the canonical source of .studypack files. -->
	<!-- Conforms to public.json (payload format), public.data (so Finder/Files recognize -->
	<!-- the file), and public.content (so the type can be shared via AirDrop). -->
	<key>UTExportedTypeDeclarations</key>
	<array>
		<dict>
			<key>UTTypeIdentifier</key>
			<string>com.mangolassiglazers.learningapp.studypack</string>
			<key>UTTypeDescription</key>
			<string>Study Pack</string>
			<key>UTTypeConformsTo</key>
			<array>
				<string>public.json</string>
				<string>public.data</string>
				<string>public.content</string>
			</array>
			<key>UTTypeTagSpecification</key>
			<dict>
				<key>public.filename-extension</key>
				<array>
					<string>studypack</string>
				</array>
				<key>public.mime-type</key>
				<array>
					<string>application/x-studypack</string>
				</array>
			</dict>
		</dict>
	</array>

	<!-- Document type registration: tells iOS this app handles .studypack files. -->
	<key>CFBundleDocumentTypes</key>
	<array>
		<dict>
			<key>CFBundleTypeName</key>
			<string>Study Pack</string>
			<key>CFBundleTypeRole</key>
			<string>Editor</string>
			<key>LSHandlerRank</key>
			<string>Owner</string>
			<key>LSItemContentTypes</key>
			<array>
				<string>com.mangolassiglazers.learningapp.studypack</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
